generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int     @id @default(autoincrement())
  nombre          String  @default("Admin")
  usuario         String  @unique
  email           String  @unique
  password        String
  esSuperAdmin    Boolean @default(false)
  esAdmin         Boolean @default(false)
  permisoFinanzas Boolean @default(false)
  permisoTurnos   Boolean @default(false)
  permisoClientes Boolean @default(false)
  permisoPlanes   Boolean @default(false)
  permisoFeriados Boolean @default(false)

  @@map("usuarios")
}

model ConfiguracionLocal {
  id                       Int       @id @default(autoincrement())
  logo_url                 String?
  nombre                   String?
  direccion                String?
  telefono                 String?
  instagram                String?
  whatsapp                 String?
  hora_apertura            DateTime? @db.Time(0)
  hora_cierre              DateTime? @db.Time(0)
  capacidad_max_hora       Int       @default(0)
  margen_cancelacion_horas Int       @default(0)
  bloqueo_capacidad        Boolean   @default(false)

  @@map("configuracion_local")
}

model Plan {
  id              Int         @id @default(autoincrement())
  codigo          String?     @unique
  nombre          String
  etiqueta        String?
  precio          Decimal     @db.Decimal(10, 2)
  frecuencia      String
  caracteristicas String?     @db.Text
  observaciones   String?     @db.Text
  activo          Boolean     @default(true)
  categorias      Categoria[]

  @@map("planes")
}

model Cliente {
  id               Int            @id @default(autoincrement())
  codigo_socio     String?        @unique
  nombre           String
  apellido         String
  dni_cuit         String         @unique
  email            String?        @unique
  password         String?
  telefono         String?
  fecha_inicio     DateTime?      @db.Date
  observaciones    String?        @db.Text
  estado_pago      EstadoPago     @default(ALDIA)
  estado_cliente   EstadoCliente  @default(ACTIVO)
  categoriaId      Int?
  es_socio         Boolean        @default(false)
  categoria        Categoria?     @relation(fields: [categoriaId], references: [id])
  turnosCliente    TurnoCliente[]
  rutinas          Rutina[]
  records          Record[]
  pagos            Pago[]
  vencimientoCuota DateTime?

  @@index([categoriaId], map: "clientes_categoriaId_fkey")
  @@map("clientes")
}

model Profesional {
  id            Int             @id @default(autoincrement())
  nombre        String
  apellido      String
  dni           String          @unique
  especialidad  String?
  matricula     String?
  email         String?         @unique
  telefono      String?
  activo        Boolean         @default(true)
  turnosCliente TurnoCliente[]
  categorias    Categoria[]
  horarios      HorarioConfig[]

  @@map("profesionales")
}

model HorarioConfig {
  id            Int            @id @default(autoincrement())
  dia_semana    Int
  hora_inicio   DateTime       @db.Time(0)
  hora_fin      DateTime       @db.Time(0)
  activo        Boolean        @default(true)
  cupo_maximo   Int?
  categoriaId   Int?
  profesionalId Int?
  profesional   Profesional?   @relation(fields: [profesionalId], references: [id])
  categoria     Categoria?     @relation(fields: [categoriaId], references: [id])
  turnos        TurnoCliente[]

  @@map("horarios_config")
}

model TurnoCliente {
  id            Int           @id @default(autoincrement())
  fecha         DateTime      @db.Date
  horarioId     Int
  clienteId     Int
  profesionalId Int?
  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  horario       HorarioConfig @relation(fields: [horarioId], references: [id])
  profesional   Profesional?  @relation(fields: [profesionalId], references: [id])

  @@unique([fecha, horarioId, clienteId])
  @@index([clienteId], map: "turnos_clientes_clienteId_fkey")
  @@index([horarioId], map: "turnos_clientes_horarioId_fkey")
  @@index([profesionalId], map: "turnos_clientes_profesionalId_fkey")
  @@map("turnos_clientes")
}

model Categoria {
  id            Int             @id @default(autoincrement())
  nombre        String
  activo        Boolean         @default(true)
  planId        Int?
  plan          Plan?           @relation(fields: [planId], references: [id])
  rubro_sector  String?
  color         String?
  profesionalId Int?
  profesional   Profesional?    @relation(fields: [profesionalId], references: [id])
  clientes      Cliente[]
  horarios      HorarioConfig[]

  @@index([planId], map: "categorias_planId_fkey")
  @@map("categorias")
}

enum EstadoPago {
  ALDIA
  MOROSO
}

enum EstadoCliente {
  ACTIVO
  INACTIVO
}

model Configuracion {
  id                       Int     @id @default(1)
  nombreGimnasio           String?
  logoBase64               String? @db.LongText
  bloqueoCapacidad         Boolean @default(false)
  cupoGlobal               Int     @default(15)
  limiteCancelacionMinutos Int     @default(60)
  profesoresPorTurno       Boolean @default(false)
  adminNombre              String?
  adminApellido            String?
  adminDni                 String?
  adminEmail               String?
  diasApertura             String? @default("1,2,3,4,5,6")

  @@map("configuracion")
}

model Aviso {
  id         Int       @id @default(autoincrement())
  titulo     String
  mensaje    String?   @db.Text
  tipo       String    @default("INFO")
  fechaDesde DateTime
  fechaHasta DateTime?
  activo     Boolean   @default(true)

  @@map("avisos")
}

model CalendarioNota {
  id         Int     @id @default(autoincrement())
  fecha      String // Formato YYYY-MM-DD
  contenido  String  @db.Text
  horaAlarma String? // Formato HH:MM (Opcional)
  notificado Boolean @default(false)

  @@map("calendario_notas")
}

model Rutina {
  id         Int               @id @default(autoincrement())
  nombre     String
  clienteId  Int
  cliente    Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ejercicios RutinaEjercicio[]
  createdAt  DateTime          @default(now())

  @@map("rutinas")
}

model RutinaEjercicio {
  id              Int     @id @default(autoincrement())
  rutinaId        Int
  rutina          Rutina  @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  nombreEjercicio String
  dia             String?
  series          Int
  repeticiones    String
  pesoSugerido    String?
  pesoReal        String?

  @@map("rutina_ejercicios")
}

model Record {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ejercicio  String
  pesoMaximo Float
  fecha      DateTime @default(now())

  @@unique([clienteId, ejercicio])
  @@map("records")
}

model Pago {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  monto      Float
  metodoPago String // Ej: 'EFECTIVO', 'TRANSFERENCIA', 'MERCADO_PAGO'
  concepto   String // Ej: 'Cuota Mensual Pase Libre'
  fecha      DateTime @default(now())
  notas      String?
  estado     String   @default("APROBADO")
}
