generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  rol      String @default("ADMIN")

  @@map("usuarios")
}

model ConfiguracionLocal {
  id                       Int       @id @default(autoincrement())
  logo_url                 String?
  nombre                   String?
  direccion                String?
  telefono                 String?
  instagram                String?
  whatsapp                 String?
  hora_apertura            DateTime? @db.Time(0)
  hora_cierre              DateTime? @db.Time(0)
  capacidad_max_hora       Int       @default(0)
  margen_cancelacion_horas Int       @default(0)
  bloqueo_capacidad        Boolean   @default(false)

  @@map("configuracion_local")
}

model Plan {
  id              Int        @id @default(autoincrement())
  codigo          String?    @unique
  nombre          String
  etiqueta        String?
  precio          Decimal    @db.Decimal(10, 2)
  frecuencia      String
  caracteristicas String?    @db.Text
  observaciones   String?    @db.Text
  activo          Boolean    @default(true)
  categoriaId     Int?
  clientes        Cliente[]
  categoria       Categoria? @relation(fields: [categoriaId], references: [id])

  @@index([categoriaId], map: "planes_categoriaId_fkey")
  @@map("planes")
}

model Cliente {
  id             Int            @id @default(autoincrement())
  codigo_socio   String?        @unique
  nombre         String
  apellido       String
  dni_cuit       String         @unique
  email          String?        @unique
  telefono       String?
  fecha_inicio   DateTime?      @db.Date
  observaciones  String?        @db.Text
  estado_pago    EstadoPago     @default(ALDIA)
  estado_cliente EstadoCliente  @default(ACTIVO)
  planId         Int?
  es_socio       Boolean        @default(false)
  plan           Plan?          @relation(fields: [planId], references: [id])
  turnos         TurnoCliente[]

  @@index([planId], map: "clientes_planId_fkey")
  @@map("clientes")
}

model Profesional {
  id           Int     @id @default(autoincrement())
  nombre       String
  apellido     String
  dni          String  @unique
  especialidad String?
  matricula    String?
  email        String? @unique
  telefono     String?
  activo       Boolean @default(true)

  @@map("profesionales")
}

model HorarioConfig {
  id          Int            @id @default(autoincrement())
  dia_semana  Int
  hora_inicio DateTime       @db.Time(0)
  hora_fin    DateTime       @db.Time(0)
  turnos      TurnoCliente[]

  @@map("horarios_config")
}

model TurnoCliente {
  id        Int           @id @default(autoincrement())
  fecha     DateTime      @db.Date
  horarioId Int
  clienteId Int
  cliente   Cliente       @relation(fields: [clienteId], references: [id])
  horario   HorarioConfig @relation(fields: [horarioId], references: [id])

  @@unique([fecha, horarioId, clienteId])
  @@index([clienteId], map: "turnos_clientes_clienteId_fkey")
  @@index([horarioId], map: "turnos_clientes_horarioId_fkey")
  @@map("turnos_clientes")
}

model Categoria {
  id           Int     @id @default(autoincrement())
  nombre       String
  rubro_sector String?
  color        String?
  planes       Plan[]

  @@map("categorias")
}

enum EstadoPago {
  ALDIA
  MOROSO
}

enum EstadoCliente {
  ACTIVO
  INACTIVO
}
